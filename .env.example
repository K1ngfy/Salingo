# 本地开发推荐：密钥只由本地 AI 代理读取，不进入浏览器包。
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
# 可选：覆盖本地统一代理端口（默认 43128）。
# SALINGO_AI_PROXY_PORT=43128

# 可公开写入前端构建的非敏感默认值。
NEXT_PUBLIC_AI_BASE_URL=https://api.openai.com/v1
NEXT_PUBLIC_AI_MODEL=gpt-5-mini

# 可选：覆盖默认代理。Sites 部署默认使用同源 /api/ai，无需设置。
# NEXT_PUBLIC_AI_PROXY_URL=https://your-proxy.example.com

# Sites 托管环境变量：AI_API_KEY 必须标记为 secret，不得使用 NEXT_PUBLIC_ 前缀。
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
